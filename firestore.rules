rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function esAdmin() {
      return request.auth != null
        && request.auth.token.email == "espaciomimart36@gmail.com";
    }

    function noCambiaCamposAdmin() {
      return !(request.resource.data.diff(resource.data).affectedKeys()
               .hasAny(['membershipActive', 'membresia', 'hoursBalance', 'role']));
    }

    match /clients/{clientId} {
      allow read:   if true;
      allow write:  if esAdmin();
      allow update: if noCambiaCamposAdmin();
    }

    match /historias/{historiaId} {
      allow read:   if esAdmin();
      allow write:  if true;
    }

    match /reservas/{reservaId} {
      allow read:   if true;
      allow create: if true;
      allow update, delete: if esAdmin();
    }

    // Control atomico anti-solapamiento de turnos
    match /reservas_slots/{slotId} {
      allow read:   if true;
      allow write:  if true;
    }

    match /horarios/{horarioId} {
      allow read:   if true;
      allow write:  if esAdmin();
    }

    match /calendarExceptions/{excId} {
      allow read:   if true;
      allow write:  if esAdmin();
    }

    match /configuracion/{docId} {
      allow read:   if true;
      allow write:  if esAdmin();
    }

    match /services/{serviceId} {
      allow read:   if true;
      allow write:  if esAdmin();
    }

    match /pedidosKit/{pedidoId} {
      allow read:   if esAdmin() || request.auth != null;
      allow create: if true;
      allow write:  if esAdmin();
    }

  }
}
